<!--pages/address-edit/address-edit.wxml-->
<view class="container">
  <view class="form-card">
    <view class="form-item">
      <text class="label">收货人</text>
      <input class="input" placeholder="姓名" value="{{name}}" bindinput="onInput" data-field="name" />
    </view>
    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" placeholder="手机号" type="number" value="{{phone}}" bindinput="onInput" data-field="phone" />
    </view>
    <view class="form-item" bindtap="chooseRegion">
      <text class="label">所在地区</text>
      <text class="region-text">{{regionStr || '请选择'}}</text>
    </view>
    <view class="form-item">
      <text class="label">详细地址</text>
      <input class="input" placeholder="街道、门牌号等" value="{{detail}}" bindinput="onInput" data-field="detail" />
    </view>
    <view class="form-item switch-item">
      <text class="label">设为默认地址</text>
      <switch checked="{{isDefault}}" bindchange="onSwitchChange" />
    </view>
    <button class="save-btn" bindtap="saveAddress">保存</button>
  </view>
</view>
.page {
  padding: 30rpx;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.page-hd {
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #0F172A;
}

.info-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #64748B;
}

.info-value {
  font-size: 28rpx;
  color: #0F172A;
  font-weight: 500;
}

.status-tag {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  background: #FFF3E0;
  color: #FF8C00;
}

.status-tag.active {
  background: #E8F5E9;
  color: #4CAF50;
}

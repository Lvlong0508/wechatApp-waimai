<view class="page">
  <view class="page-hd">
    <text class="page-title">商品管理</text>
  </view>

  <view class="goods-list">
    <view class="goods-item" wx:for="{{goods}}" wx:key="id">
      <image class="goods-img" src="{{item.image}}" mode="aspectFill" />
      <view class="goods-info">
        <text class="goods-name">{{item.name}}</text>
        <text class="goods-price">¥{{item.price}}</text>
        <text class="goods-status {{item.status === 1 ? 'on' : 'off'}}">
          {{item.status === 1 ? '上架中' : '已下架'}}
        </text>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{!goods.length}}">
    <text>暂无商品</text>
  </view>
</view>

<merchant-tabbar active="goods" />

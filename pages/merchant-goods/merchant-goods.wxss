.page {
  padding: 30rpx;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.page-hd {
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #0F172A;
}

.goods-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.goods-item {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.goods-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background: #F1F5F9;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.goods-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #0F172A;
}

.goods-price {
  font-size: 28rpx;
  color: #EA580C;
  font-weight: 600;
}

.goods-status {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  align-self: flex-start;
}

.goods-status.on {
  background: #E8F5E9;
  color: #4CAF50;
}

.goods-status.off {
  background: #FFF3E0;
  color: #FF8C00;
}

.empty {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
  color: #94A3B8;
  font-size: 28rpx;
}

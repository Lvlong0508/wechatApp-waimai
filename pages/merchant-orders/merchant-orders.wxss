.page {
  padding: 30rpx;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.page-hd {
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #0F172A;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.order-hd {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.order-no {
  font-size: 26rpx;
  color: #64748B;
}

.order-status {
  font-size: 24rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.order-status.s0 { background: #FFF3E0; color: #FF8C00; }
.order-status.s1 { background: #E3F2FD; color: #2196F3; }
.order-status.s2 { background: #E8F5E9; color: #4CAF50; }
.order-status.s3 { background: #F1F5F9; color: #94A3B8; }

.order-body {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.order-amount {
  font-size: 32rpx;
  font-weight: 700;
  color: #EA580C;
}

.order-time {
  font-size: 24rpx;
  color: #94A3B8;
}

.order-items {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.order-item-name {
  font-size: 24rpx;
  color: #64748B;
  background: #F8FAFC;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.empty {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
  color: #94A3B8;
  font-size: 28rpx;
}

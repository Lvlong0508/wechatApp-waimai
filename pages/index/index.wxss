/* ===== Design Tokens ===== */
.page {
  --c-primary: #EA580C;
  --c-primary-light: #F97316;
  --c-primary-lighter: #FDE9DA;
  --c-accent: #2563EB;
  --c-white: #FFFFFF;
  --c-bg: #FFF7ED;
  --c-text-primary: #0F172A;
  --c-text-secondary: #64748B;
  --c-text-tertiary: #94A3B8;
  --c-border: #E2E8F0;
  --c-shadow: rgba(234, 88, 12, 0.12);

  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;

  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;
  --space-2xl: 64rpx;

  --ease-out: cubic-bezier(0.22, 1, 0.36, 1);
  --duration-fast: 200ms;
  --duration-normal: 300ms;

  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, var(--c-primary) 0%, var(--c-primary-light) 40%, var(--c-bg) 40%);
}

/* ===== Hero ===== */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-2xl) var(--space-lg) var(--space-xl);
}

.hero-icon {
  font-size: 96rpx;
  margin-bottom: var(--space-md);
  filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.1));
  animation: float 3s var(--ease-out) infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

.hero-title {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--c-white);
  letter-spacing: 4rpx;
  margin-bottom: var(--space-sm);
}

.hero-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  letter-spacing: 2rpx;
}

/* ===== Entry Cards ===== */
.entry-group {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  padding: 0 var(--space-lg);
  animation: fadeUp 0.6s var(--ease-out) 0.2s both;
}

@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.entry-card {
  display: flex;
  align-items: center;
  background: var(--c-white);
  border-radius: var(--radius-lg);
  padding: var(--space-lg) var(--space-md);
  box-shadow: 0 4rpx 24rpx var(--c-shadow);
  transition: transform var(--duration-fast) var(--ease-out),
              box-shadow var(--duration-fast) var(--ease-out);
  will-change: transform;
}

.entry-card:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 12rpx var(--c-shadow);
}

.entry-card:nth-child(2) {
  animation-delay: 0.3s;
}

.entry-icon-box {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-md);
  flex-shrink: 0;
  position: relative;
  overflow: hidden;
}

.entry-icon-box::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.2) 0%, transparent 50%);
}

.user-icon-box {
  background: linear-gradient(135deg, var(--c-primary), var(--c-primary-light));
}

.merchant-icon-box {
  background: linear-gradient(135deg, var(--c-accent), #3B82F6);
}

.entry-icon-text {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--c-white);
  position: relative;
  z-index: 1;
}

.entry-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  min-width: 0;
}

.entry-label {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--c-text-primary);
  line-height: 1.3;
}

.entry-desc {
  font-size: 26rpx;
  color: var(--c-text-secondary);
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.entry-arrow {
  font-size: 48rpx;
  color: var(--c-border);
  font-weight: 300;
  margin-left: var(--space-sm);
  flex-shrink: 0;
}

/* ===== Footer ===== */
.footer {
  margin-top: auto;
  padding: var(--space-xl) var(--space-lg) var(--space-lg);
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: var(--c-text-tertiary);
}

/* ===== Loading Overlay ===== */
.loading-overlay {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(15, 23, 42, 0.45);
  opacity: 0;
  pointer-events: none;
  transition: opacity var(--duration-normal) var(--ease-out);
  backdrop-filter: blur(4rpx);
  -webkit-backdrop-filter: blur(4rpx);
}

.loading-overlay.active {
  opacity: 1;
  pointer-events: auto;
}

.loading-dialog {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-md);
  background: var(--c-white);
  padding: var(--space-xl) var(--space-2xl);
  border-radius: var(--radius-lg);
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.15);
  transform: scale(0.9) translateY(12rpx);
  transition: transform var(--duration-normal) var(--ease-out);
}

.loading-overlay.active .loading-dialog {
  transform: scale(1) translateY(0);
}

.loading-spinner {
  position: relative;
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.spinner-ring {
  position: absolute;
  inset: 0;
  border: 6rpx solid var(--c-primary-lighter);
  border-top-color: var(--c-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.spinner-icon {
  font-size: 36rpx;
  z-index: 1;
}

.loading-text {
  font-size: 28rpx;
  color: var(--c-text-secondary);
  font-weight: 500;
}

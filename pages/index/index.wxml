<view class="page">
  <view class="hero">
    <view class="hero-icon">🍜</view>
    <view class="hero-title">校园外卖</view>
    <view class="hero-subtitle">一键点餐 · 极速送达</view>
  </view>

  <view class="entry-group">
    <view class="entry-card entry-user" bindtap="goUser">
      <view class="entry-icon-box user-icon-box">
        <text class="entry-icon-text">U</text>
      </view>
      <view class="entry-info">
        <text class="entry-label">用户端</text>
        <text class="entry-desc">浏览店铺 · 下单点餐</text>
      </view>
      <text class="entry-arrow">›</text>
    </view>

    <view class="entry-card entry-merchant" bindtap="goMerchant">
      <view class="entry-icon-box merchant-icon-box">
        <text class="entry-icon-text">M</text>
      </view>
      <view class="entry-info">
        <text class="entry-label">商家端</text>
        <text class="entry-desc">管理店铺 · 处理订单</text>
      </view>
      <text class="entry-arrow">›</text>
    </view>
  </view>

  <view class="footer">
    <text class="footer-text">校园外卖平台</text>
  </view>

  <view class="loading-overlay {{loading.visible ? 'active' : ''}}">
    <view class="loading-dialog">
      <view class="loading-spinner">
        <view class="spinner-ring"></view>
        <view class="spinner-icon">🍜</view>
      </view>
      <text class="loading-text">{{loading.text}}</text>
    </view>
  </view>
</view>

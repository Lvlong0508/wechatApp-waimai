.page {
  padding: 30rpx;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.header {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #EA580C, #F97316);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  margin-right: 24rpx;
  border: 4rpx solid rgba(255,255,255,0.3);
  background: #fff;
}

.info {
  flex: 1;
}

.name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.score {
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  background: rgba(255,255,255,0.2);
  color: rgba(255,255,255,0.9);
}

.status-tag.active {
  background: rgba(255,255,255,0.95);
  color: #EA580C;
  font-weight: 600;
}

.stats {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.stat-num {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #0F172A;
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #94A3B8;
}

.quick-actions {
  display: flex;
  gap: 20rpx;
}

.action-card {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.action-card:active {
  transform: scale(0.96);
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.action-label {
  font-size: 24rpx;
  color: #64748B;
}

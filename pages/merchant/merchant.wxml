<view class="page">
  <view class="header">
    <image class="logo" src="{{shop.logo}}" mode="aspectFill" />
    <view class="info">
      <view class="name">{{shop.name}}</view>
      <view class="desc">{{shop.description}}</view>
      <view class="meta">
        <text class="score">⭐ {{shop.score}}</text>
        <text class="status-tag {{shop.status === 1 ? 'active' : ''}}">
          {{shop.status === 1 ? '营业中' : '待审核'}}
        </text>
      </view>
    </view>
  </view>

  <view class="stats">
    <view class="stat-item">
      <text class="stat-num">0</text>
      <text class="stat-label">今日订单</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">¥0</text>
      <text class="stat-label">今日收入</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{shop.score}}</text>
      <text class="stat-label">店铺评分</text>
    </view>
  </view>

  <view class="quick-actions">
    <view class="action-card" bindtap="goGoods">
      <view class="action-icon goods-bg">📦</view>
      <text class="action-label">商品管理</text>
    </view>
    <view class="action-card" bindtap="goOrders">
      <view class="action-icon orders-bg">📋</view>
      <text class="action-label">订单管理</text>
    </view>
    <view class="action-card" bindtap="goManage">
      <view class="action-icon manage-bg">⚙️</view>
      <text class="action-label">店铺设置</text>
    </view>
  </view>
</view>

<merchant-tabbar active="home" />
